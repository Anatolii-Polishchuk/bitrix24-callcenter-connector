# ── Битрикс24 входящий вебхук ─────────────────────────────────────────────
# Полный URL вебхука из портала: Разработчикам → Другое → Входящий вебхук.
# Формат: https://<portal>.bitrix24.<tld>/rest/<userId>/<secret>/
# СЕКРЕТ ХРАНИТСЯ ТОЛЬКО ЗДЕСЬ/В ОКРУЖЕНИИ. Никогда не коммить .env.
B24_HOOK=https://your-portal.bitrix24.ru/rest/1/xxxxxxxxxxxxxxxx/

# ── Приём исходящих вебхуков (событий) от Битрикс24 ───────────────────────
# "application_token", который Битрикс шлёт в теле события. Задаётся при
# настройке обработчика события/исходящего вебхука в портале. Мы сверяем его
# в constant-time и молча дропаем событие при несовпадении.
B24_APPLICATION_TOKEN=

# HTTP-порт Express-приёмника событий (/webhook, /health).
PORT=3000

# ── Тюнинг устойчивости (необязательно; разумные значения по умолчанию) ────
# Тариф: 'default' (2 req/s) | 'enterprise' (5 req/s) — влияет на лимитеры SDK.
B24_TARIFF=default
# Ретраи временных ошибок (QUERY_LIMIT_EXCEEDED/OPERATION_TIME_LIMIT) в SDK.
B24_MAX_RETRIES=3
B24_RETRY_DELAY_MS=1000
# Ретрай сетевых ошибок для ЧТЕНИЙ (идемпотентно). Записи не ретраятся никогда.
B24_READ_NETWORK_RETRIES=4

# ── Очередь событий ───────────────────────────────────────────────────────
QUEUE_CONCURRENCY=4
QUEUE_DATA_DIR=.data
# Сколько раз воркер пробует обработать событие перед отправкой в dead-letter.
QUEUE_MAX_ATTEMPTS=5

# ── Логирование ───────────────────────────────────────────────────────────
LOG_LEVEL=info
